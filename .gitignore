# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/

# Release artifacts: the frozen, versioned release bundle under release/ is an
# immutable deliverable (wheel + checksum) and must be tracked despite the
# throwaway-build `dist/` rule above.
!release/**/dist/

# Virtual environments
.venv/
venv/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
desktop.ini
Thumbs.db
.DS_Store

# Runtime locks (generated at runtime)
.specify/governance.lock/

# Private keys — NEVER commit (project is a public trust/governance repo)
*.pem
.specify/keys/

# Scratch / throwaway working dir
scratch/

# Runtime agent registry (generated at boot, contains no secrets)
.specify/agents.json

# Repository-local temporary audit & workspace directories
.audit-clean/
.audit-venv/
.venv-install/
.gemini/
.specify/device/

.gemini/

